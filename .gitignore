# ============================================================
# Task Manager — .gitignore
# ============================================================

# ─── Secrets (.env) — NEVER commit ─────────────────────────
.env
.env.*
!.env.example

# ─── Configuration (.config) — safe to commit ───────────────
# .config files are tracked (they contain no secrets)
!.config

# ─── Python (Backend) ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# MyPy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# ─── Node / Frontend (Vite + React) ─────────────────────────
node_modules/
frontend/node_modules/

# Build output
dist/
frontend/dist/

# Vite cache
.vite/
frontend/.vite/

# ─── Logs ───────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Docker ─────────────────────────────────────────────────
# Keep docker-compose.yml and Dockerfiles tracked.
# Ignore override files with local secrets.
docker-compose.override.yml

# ─── OS & Editor ────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# VSCode
.vscode/
!.vscode/extensions.json

# JetBrains IDEs
.idea/

# ─── Misc ───────────────────────────────────────────────────
*.sqlite3
*.db
*.bak
*.swp
*.swo
