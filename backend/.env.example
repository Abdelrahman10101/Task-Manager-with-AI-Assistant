# ============================================================
# BACKEND SECRETS TEMPLATE — copy to .env and fill in values
# cp .env.example .env
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Full PostgreSQL connection string (includes credentials)
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<dbname>

# ── JWT ──────────────────────────────────────────────────────
# Strong random secret — generate with: openssl rand -hex 32
SECRET_KEY=

# Signing algorithm — HS256 (symmetric) or RS256 (asymmetric)
ALGORITHM=HS256

# Token expiry in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── HuggingFace AI ───────────────────────────────────────────
# Free token from: https://huggingface.co/settings/tokens
# Leave empty to disable AI features (fallback mode will be used)
HF_TOKEN=

# HuggingFace router base URL (OpenAI-compatible)
# Default: https://router.huggingface.co/v1
# HUGGINGFACE_API_URL=https://router.huggingface.co/v1

# Model ID to use via the router — override to switch without code changes
# Default: openai/gpt-oss-20b:novita
# HF_MODEL=openai/gpt-oss-20b:novita

