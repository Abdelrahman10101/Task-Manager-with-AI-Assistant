# ============================================================
# BACKEND SECRETS TEMPLATE — copy to .env and fill in values
# cp .env.example .env
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Full PostgreSQL connection string (includes credentials)
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<dbname>

# ── JWT ──────────────────────────────────────────────────────
# Strong random secret — generate with: openssl rand -hex 32
SECRET_KEY=

# Signing algorithm — HS256 (symmetric) or RS256 (asymmetric)
ALGORITHM=HS256

# ── HuggingFace ──────────────────────────────────────────────
# Free token from: https://huggingface.co/settings/tokens
# Leave empty to disable AI features
HF_TOKEN=
